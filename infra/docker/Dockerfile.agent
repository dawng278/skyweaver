# ─── Stage 1: Build ──────────────────────────────────────
FROM golang:1.21-alpine AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -ldflags="-s -w" -o skyweaver-agent ./cmd/

# ─── Stage 2: Minimal Runtime ────────────────────────────
FROM scratch

COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /build/skyweaver-agent /skyweaver-agent

ENTRYPOINT ["/skyweaver-agent"]
