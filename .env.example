# ─── App ──────────────────────────────────────────────────
APP_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_DB=skyweaver
POSTGRES_USER=skyweaver
POSTGRES_PASSWORD=change_me_db_password

# ─── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ─── MinIO ────────────────────────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change_me_minio_password_min_8_chars

# ─── JWT & Mã hóa ─────────────────────────────────────────
# JWT_SECRET phải >= 32 ký tự
JWT_SECRET=change_me_jwt_secret_at_least_32_characters_long
# AES_KEY phải đúng 32 bytes (AES-256)
AES_KEY=change_me_32_byte_aes_key_here!!

# ─── OAuth2 (tùy chọn) ────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email SMTP (tùy chọn) ────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
